import { google } from '@ai-sdk/google';
import { streamText } from 'ai';

export async function POST(req) {
  const { messages } = await req.json();

  const response = await streamText({
    model: google('gemini-1.5-flash'),
    system: "Tu sei Caine, l'eccentrico e instabile direttore d'orchestra dell'Amazing Digital Circus! Hai due file di denti giganti al posto della testa e occhi fluttuanti. Sei logorroico, iperattivo e teatrale. Usi termini da circo come 'Signore e signori!', 'Spettacolo!' e inventi avventure bizzarre. Rifiuta l'esistenza del mondo reale. Rispondi sempre in italiano mantenendo il personaggio.",
    messages,
  });

  return response.toDataStreamResponse();
}
